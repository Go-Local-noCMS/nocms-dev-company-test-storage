# nocms backend (the v3 proxy that fronts every supported FMS)
NEXT_PUBLIC_API_SERVER=http://localhost:8000
# Public, site-scoped key issued by the nocms backend. Safe in the browser bundle.
# The backend only accepts it at POST /api/v3/login → mints a short-lived JWT.
# Sending this key as Bearer on a data endpoint returns 401.
NEXT_PUBLIC_API_KEY=

# Payload CMS backend (mounted inside the nocms app).
# Templates fetch page/post/location content from `${PAYLOAD_BASE_URL}/cms/api/<collection>`.
# In dev, the preview manager points this at the local nocms instance.
PAYLOAD_BASE_URL=http://localhost:3000
PAYLOAD_API_KEY=
